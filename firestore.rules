rules_version = '2'; 
service cloud.firestore { 
  match /databases/{database}/documents { 
    function isSignedIn() { 
      return request.auth != null; 
    } 
    function isAdmin() { 
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    } 
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    } 

    match /schedule/{itemId} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    } 
    
    match /users/{userId} { 
      allow read: if isOwner(userId) || isAdmin(); 
      allow create: if isSignedIn() && request.resource.data.role != 'admin'; 
      allow update, delete: if isOwner(userId) || isAdmin(); 
      
      match /bookings/{bookingId} { 
        allow read, create: if isOwner(userId) || isAdmin(); 
        allow update, delete: if isAdmin() || (isOwner(userId) && resource.data.createdBy == request.auth.uid); 
      } 
      
      match /payments/{paymentId} { 
        allow read: if isOwner(userId) || isAdmin(); 
        allow create: if isOwner(userId); 
        allow update, delete: if isAdmin(); 
      } 
    } 
    
    match /{path=**}/bookings/{bookingId} { 
      allow read: if isAdmin(); 
    } 
    match /{path=**}/payments/{paymentId} { 
      allow read: if isAdmin(); 
    } 
  } 
}
